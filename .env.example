# Infrastructure-level only — everything else (Pushover, notify-on-success,
# debug screenshots, headless/visible mode) is configured from the
# dashboard's Settings page after the container is running, and persists to
# /data/settings.json.

DATA_PATH=/data/
PORT=8080

# Used only the very first time the container starts (before data/schedule.json
# exists) — after that, change the schedule from the dashboard.
DEFAULT_CRON=0 9 * * *

# Optional: set your container's local timezone so the cron schedule and
# timestamps match your clock, e.g. TZ=Europe/London
# TZ=

# Optional first-run seed values for the Settings page (you can just set these
# in the UI instead — env vars here are only read if settings.json doesn't exist yet).
# PUSHOVER_USER_KEY=
# PUSHOVER_APP_TOKEN=
# NOTIFY_ON_SUCCESS=false
# DEBUG_SCREENSHOTS=true
# FORCE_HEADLESS=
