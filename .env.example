# Required
LOGINNAME=your-email@example.com
PASSWORD=your-password

# Optional (defaults shown)
IS_DOCKER=true
DATA_PATH=/data/
DEBUG_SCREENSHOTS=true

# Leave unset for auto (try headless, fall back to visible on Turnstile block/error).
# Set to "true" to force headless-only, "false" to force visible-only.
# FORCE_HEADLESS=
