# Data, screenshots, web UI
DATA_PATH=/data/
DEBUG_SCREENSHOTS=true
PORT=8080

# Used only the very first time the container starts (before data/schedule.json
# exists) — after that, change the schedule from the dashboard.
DEFAULT_CRON=0 9 * * *

# Optional: set your container's local timezone so the cron schedule and
# timestamps match your clock, e.g. TZ=Europe/London
# TZ=

# Pushover (optional — leave both blank to disable notifications entirely)
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=
# Notify on success/already-claimed too, not just failures
NOTIFY_ON_SUCCESS=false
